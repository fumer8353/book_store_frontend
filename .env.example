# Local development
VITE_API_URL=http://localhost:5000/api

# Azure Static Web Apps (production)
# Vite inlines env vars at build time. Set VITE_API_URL in GitHub repository
# Settings → Secrets and variables → Actions → Variables (or Secrets), then
# redeploy. Example:
# VITE_API_URL=https://your-backend.azurewebsites.net/api
