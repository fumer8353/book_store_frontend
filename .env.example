# Local dev — full backend URL (or use /api with Vite proxy in vite.config.ts)
VITE_API_URL=http://localhost:5000/api

# Azure Static Web Apps — set the same variable in Azure portal
# Configuration → Environment variables (used at build time):
# VITE_API_URL=https://bookstore-backend-g0f7bzbvargjedc7.australiaeast-01.azurewebsites.net/api
#
# If unset at build, production falls back to /api and staticwebapp.config.json
# proxies those requests to the backend.
