# Local development — copy to .env
VITE_API_URL=http://localhost:5000/api

# Azure production — VITE_API_URL must be available during the GitHub Actions build.
# 1. Azure portal: Static Web App → Configuration → Environment variables
# 2. GitHub repo: Settings → Secrets and variables → Actions → Variables
#
# Use the same name and value in both places:
# VITE_API_URL=https://your-backend.azurewebsites.net/api
#
# The Azure portal value alone is not passed to the GitHub build runner.
# The GitHub Actions variable is required for npm run build to succeed.
