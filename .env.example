# Local development (npm run dev uses Vite proxy to localhost:5000)
VITE_API_URL=http://localhost:5000/api

# Azure Static Web Apps — REQUIRED for production builds
# GitHub → Settings → Secrets and variables → Actions → Variables
# Name:  VITE_API_URL
# Value: https://YOUR-BACKEND-URL/api
# Example: https://bookstore-api.azurewebsites.net/api
#
# After setting the variable, push to main to trigger a new deploy.
